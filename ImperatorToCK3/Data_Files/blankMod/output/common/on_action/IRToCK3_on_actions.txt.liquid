# Make sure you don't use "irtock3_on_game_start_after_lobby" as an on_action name to prevent it overwriting another on_action setup internally be the converter

# root = NONE
on_game_start = {
	on_actions = {
		IRToCK3_game_start_onaction_effects
	}
}

# root = NONE
on_game_start_after_lobby = {
	on_actions = {
		IRToCK3_game_start_after_lobby_onaction_effects
	}
}

# root = Character who changed government
# scope:old_government = Character's old government type
on_government_change = {
	on_actions = {
		IRToCK3_ritsuryo_empire_setup
	}
}

# root = Character ranking up
# scope:title = Old primary title
on_rank_up = {
	on_actions = {
		IRToCK3_ritsuryo_empire_setup
	}
}

# root = Character ranking down
# scope:title = Old primary title
on_rank_down = {
	on_actions = {
		IRToCK3_ritsuryo_empire_setup
	}
}

# root = character
# scope:previous_title = previous primary title held by character
# Not called if new primary title is the same as the previous primary title
on_primary_title_change = {
	on_actions = {
		IRToCK3_ritsuryo_multiple_empires
	}
}

# root = the new holder
# scope:title = the title that changes hands
# scope:previous_holder = previous holder. Might be dead
# scope:transfer_type = how title changed hands/was created/etc (a complete list of values this can be is in title_on_actions.txt)
on_title_gain = {
	on_actions = {
		IRToCK3_ritsuryo_multiple_empires
		IRToCK3_rome_praetorian_prefecture_name_reset
		IRToCK3_change_persia_name
		IRToCK3_rome_vassal_naming_flavor
	}
}

# root = the holder before destruction
# scope:landed_title = the title that is being destroyed
# Does *not* provide scope:transfer_type
on_title_destroyed = {
	on_actions = {
		IRToCK3_reset_persia_name
		IRToCK3_rome_vassal_naming_flavor
	}
}

# root = the old holder
# scope:title = the title that changes hands
# scope:new_holder = new holder.
on_title_lost = {
	on_actions = {
		IRToCK3_rome_vassal_naming_flavor
	}
}

# root = vassal changing their status
# scope:old_liege = the previous liege of the vassal
# It is also fired for rulers gaining independence, those can be identified by checking current liege
on_vassal_change = {
	on_actions = {
		IRToCK3_rome_vassal_naming_flavor
	}
}

# Called every Jan 1st
# Root does not exist
yearly_global_pulse = {
	on_actions = {
		IRToCK3_roman_empire_decline_effect
	}
}



IRToCK3_game_start_onaction_effects = {
	effect = {
		#################
		### Variables ###
		#################
		## Sets a global variable that could be checked by other mods that want to consider whether the IMP-CK3 converter was used, and the value of the variable indicates what the main mod being used during conversion was. This includes:
		# flag:tfe (The Fallen Eagle)
		# flag:roa (Rajas of Asia)
		# flag:wtwsms (When the World Stopped Making Sense)
		# flag:aep (Asia Expansion Project)
		# flag:vanilla_ck3 (a fallback if none of the above mods were used)
		{% if tfe %}
		set_global_variable = {
			name = irtock3_enabled
			value = flag:tfe
		}
		{% elsif roa %}
		set_global_variable = {
			name = irtock3_enabled
			value = flag:roa
		}
		{% elsif wtwsms %}
		set_global_variable = {
			name = irtock3_enabled
			value = flag:wtwsms
		}
		{% elsif aep %}
		set_global_variable = {
			name = irtock3_enabled
			value = flag:aep
		}
		{% else %}
		set_global_variable = {
			name = irtock3_enabled
			value = flag:vanilla_ck3
		}
		{% endif %}

		## Some things are setup to not trigger at the game's start date, which isn't setup by the converter. This variable will be used to handle that instead, as it will disappear after a single day, indicating you are no longer on the start date.
		set_global_variable = {
			name = irtock3_date_is_start_date
			value = yes
			days = 1
		}

		## Depending on what tier Rome title exists at game start, certain variables should be set to indicate Rome has elevated to at least that rank
		if = {
			limit = { exists = title:k_rome.holder }
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_roman_duchy_elevated
			}
		}
		else_if = {
			limit = { exists = title:e_roman_empire.holder }
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_roman_duchy_elevated
			}
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_roman_kingdom_elevated
			}
		}
		else_if = {
			limit = {
				OR = {
					exists = title:h_roman_empire.holder
					exists = title:h_western_roman_empire.holder
					exists = title:h_eastern_roman_empire.holder
					exists = title:e_western_roman_empire.holder
					exists = title:e_byzantium.holder
				}
			}
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_roman_duchy_elevated
			}
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_roman_kingdom_elevated
			}
			add_to_global_variable_list = {
				name = unavailable_unique_decisions
				target = flag:irtock3_elevate_roman_empire_decision
			}
		}

		####################################
		### Roman Praetorian Prefectures ###
		####################################
		## Base game titles that are going to be used as potential Roman Praetorian Prefecture titles need to be added to their relevant global variable lists
		# Britannia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_britannia
			EMPIRE = e_britannia
		}
		# Germania
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_germania
			EMPIRE = e_germany
		}
		# Italiae
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_italiae
			EMPIRE = e_italy
		}
		# Orientis
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_orientis
			EMPIRE = e_oriens
		}
		# Illyria
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_illyrici
			EMPIRE = e_illyria
		}
		# Pannonia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_pannonia
			EMPIRE = e_carpathia
		}
		# Scandia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_scandia
			EMPIRE = e_scandinavia
		}
		# Arabia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_arabia
			EMPIRE = e_arabia
		}
		# Persia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_persia
			EMPIRE = e_persia
		}
		# Sarmatia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_sarmatia
			EMPIRE = e_caspian-pontic_steppe
		}
		# Uralia Interior
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_uralia_interior
			EMPIRE = e_volga-ural
		}
		# Uralia Ulterior
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_uralia_ulterior
			EMPIRE = e_siberia
		}
		# Tartaria
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_tartaria
			EMPIRE = e_tartaria
		}
		# Parthia
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_parthia
			EMPIRE = e_turan
		}
		# Imoan Montem
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_imoan_montem
			EMPIRE = e_tibet
		}
		# Insulae Remotae
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_insulae_remotae
			EMPIRE = e_nusantara
		}
		# Insulae Solis
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_insulae_solis
			EMPIRE = e_japan
		}
		# Septentrionalis Deserti
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_septentrionalis_deserti
			EMPIRE = e_mongolia
		}
		# Serica Meridiana
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_serica_meridiana
			EMPIRE = e_lingnan
		}
		# Serica Occidens
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_serica_occidens
			EMPIRE = e_liangyi
		}
		# Serica Orientalis
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_serica_orientalis
			EMPIRE = e_jingyang
		}
		# Serica Septentrionalis
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_serica_septentrionalis
			EMPIRE = e_zhongyuan
		}
		# Serica Deserti
		irtock3_gamestart_add_title_to_prefecture_region_effect = {
			REGION = irtock3_rome_empire_division_serica_deserti
			EMPIRE = e_yongliang
		}

		## If a hegemony Rome title exists at game start, need to make sure it's de jure empires are properly setup as Praetorian Prefectures
		if = {
			limit = {
				OR = {
					title:h_roman_empire = { is_titular = no }
					title:h_western_roman_empire = { is_titular = no }
					title:h_eastern_roman_empire = { is_titular = no }
				}
			}

			# Britannia
			irtock3_setup_roman_prefectures_game_start = { REGION = britannia }
			# Gallarium
			irtock3_setup_roman_prefectures_game_start = { REGION = galliarum }
			# Germania
			irtock3_setup_roman_prefectures_game_start = { REGION = germania }
			# Italiae
			irtock3_setup_roman_prefectures_game_start = { REGION = italiae }
			# Libya Interior
			irtock3_setup_roman_prefectures_game_start = { REGION = libya_interior }
			# Libya Ulterior
			irtock3_setup_roman_prefectures_game_start = { REGION = libya_ulterior }
			# Aethiopia
			irtock3_setup_roman_prefectures_game_start = { REGION = aethiopia }
			# Orientis
			irtock3_setup_roman_prefectures_game_start = { REGION = orientis }
			# Illyria
			irtock3_setup_roman_prefectures_game_start = { REGION = illyrici }
			# Pannonia
			irtock3_setup_roman_prefectures_game_start = { REGION = pannonia }
			# Vistulia
			irtock3_setup_roman_prefectures_game_start = { REGION = vistulia }
			# Fennia
			irtock3_setup_roman_prefectures_game_start = { REGION = fennia }
			# Scandia
			irtock3_setup_roman_prefectures_game_start = { REGION = scandia }
			# Arabia
			irtock3_setup_roman_prefectures_game_start = { REGION = arabia }
			# Persia
			irtock3_setup_roman_prefectures_game_start = { REGION = persia }
			# Sarmatia
			irtock3_setup_roman_prefectures_game_start = { REGION = sarmatia }
			# Uralia Interior
			irtock3_setup_roman_prefectures_game_start = { REGION = uralia_interior }
			# Uralia Ulterior
			irtock3_setup_roman_prefectures_game_start = { REGION = uralia_ulterior }
			# Tartaria
			irtock3_setup_roman_prefectures_game_start = { REGION = tartaria }
			# Parthia
			irtock3_setup_roman_prefectures_game_start = { REGION = parthia }
			# Imoan Montem
			irtock3_setup_roman_prefectures_game_start = { REGION = imoan_montem }
			# India Intra Gangem
			irtock3_setup_roman_prefectures_game_start = { REGION = india_intra_gangem }
			# India Extra Gangem
			irtock3_setup_roman_prefectures_game_start = { REGION = india_extra_gangem }
			# Magna Taprobana
			irtock3_setup_roman_prefectures_game_start = { REGION = magna_taprobana }
			# Insulae Remotae
			irtock3_setup_roman_prefectures_game_start = { REGION = insulae_remotae }
			# Insulae Solis
			irtock3_setup_roman_prefectures_game_start = { REGION = insulae_solis }
			# Septentrionalis Deserti
			irtock3_setup_roman_prefectures_game_start = { REGION = septentrionalis_deserti }
			# Serica Ultima
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_ultima }
			# Serica Meridiana
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_meridiana }
			# Serica Occidens
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_occidens }
			# Serica Orientalis
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_orientalis }
			# Serica Septentrionalis
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_septentrionalis }
			# Serica Deserti
			irtock3_setup_roman_prefectures_game_start = { REGION = serica_deserti }
		}

		## If anyone holds the Rome hegemony titles at game start, they should have the Augustus trait and naming flag, and their vassals should get flags so their titles are properly named as well
		if = {
			limit = { exists = title:h_roman_empire.holder }
			title:h_roman_empire.holder = {
				add_trait = augustus
				set_variable = uses_custom_caesar_flavourization
				
				every_vassal_or_below = {
					limit = {
						any_held_title = {
							OR = {
								target_is_de_jure_liege_or_above = title:h_roman_empire
								target_is_de_jure_liege_or_above = title:h_western_roman_empire
								target_is_de_jure_liege_or_above = title:h_eastern_roman_empire
							}
						}
					}
					set_variable = use_roman_vassal_naming_flag
				}
			}
		}
		if = {
			limit = { exists = title:h_western_roman_empire.holder }
			title:h_western_roman_empire.holder = {
				add_trait = augustus
				set_variable = uses_custom_caesar_flavourization
				
				every_vassal_or_below = {
					limit = {
						any_held_title = {
							OR = {
								target_is_de_jure_liege_or_above = title:h_roman_empire
								target_is_de_jure_liege_or_above = title:h_western_roman_empire
								target_is_de_jure_liege_or_above = title:h_eastern_roman_empire
							}
						}
					}
					set_variable = use_roman_vassal_naming_flag
				}
			}
		}
		if = {
			limit = { exists = title:h_eastern_roman_empire.holder }
			title:h_eastern_roman_empire.holder = {
				add_trait = augustus
				set_variable = uses_custom_caesar_flavourization
				
				every_vassal_or_below = {
					limit = {
						any_held_title = {
							OR = {
								target_is_de_jure_liege_or_above = title:h_roman_empire
								target_is_de_jure_liege_or_above = title:h_western_roman_empire
								target_is_de_jure_liege_or_above = title:h_eastern_roman_empire
							}
						}
					}
					set_variable = use_roman_vassal_naming_flag
				}
			}
		}

		####################
		### Title Naming ###
		####################
		# Fixes weird naming of certain titles
		title:e_roman_empire = { set_definitive_form = yes }
		title:h_roman_empire = { set_definitive_form = yes }
		title:e_western_roman_empire = { set_definitive_form = yes }
		title:h_western_roman_empire = { set_definitive_form = yes }
		title:h_eastern_roman_empire = { set_definitive_form = yes }
		title:e_byzantium = { set_definitive_form = yes }
		title:h_hellenistic_empire = { set_definitive_form = yes }

		# Makes sure Persia is properly named at game start
		title:e_persia = {
			if = {
				limit = {
					NOT = { custom_title_name = irtock3_rome_empire_division_persia }
				}
				reset_title_name = yes
				set_definitive_form = yes
				if = {
					limit = { exists = holder.house }
					holder.house = { save_scope_as = new_persia_house }
					set_title_name_dynamic = new_persia_empire_name
				}
			}
		}

		##################
		### Neo-Minoan ###
		##################
		# Give Neo-Minoan the culture innovations from Cretan
		culture:neo_minoan = { get_all_innovations_from = culture:cretan }

		# Make Neo-Minoan culture only appear in provinces where the holder is of Cretan culture and is of kingdom or empire tier.
		every_ruler = {
			limit = {
				highest_held_title_tier >= tier_kingdom
				culture = culture:cretan
				any_sub_realm_county = {
					culture = culture:cretan
					duchy = title:d_krete
				}
			}
			
			# Convert the character and his entire realm from Cretan to Neo-Minoan.
			set_culture = culture:neo_minoan
			every_realm_county = {
				limit = { culture = culture:cretan }
				set_county_culture = culture:neo_minoan
			}

			every_vassal_or_below = {
				limit = { culture = culture:cretan }
				set_culture = culture:neo_minoan

				every_close_or_extended_family_member = {
					limit = { culture = culture:cretan }
					set_culture = culture:neo_minoan
				}

				every_courtier = {
					limit = { culture = culture:cretan }
					set_culture = culture:neo_minoan
				}
			}

			every_close_or_extended_family_member = {
				limit = { culture = culture:cretan }
				set_culture = culture:neo_minoan
				}

			every_courtier = {
				limit = { culture = culture:cretan }
				set_culture = culture:neo_minoan
			}
		}

		{% unless wtwsms %}
		#################
		### Indonesia ###
		#################
		## Remove Buddhism/Hinduism/Jainism from Indonesia, if relevant
		# Check if Buddhism should be removed
		if = {
			limit = {
				any_county_in_region = {
					region = converter_AUH_out_of_scope_region_faith_check
					count < 4 # Need to see if this should be changed, but want a decent chance of it happening
					faith.religion = religion:buddhism_religion
				}
			}
			religion:buddhism_religion = { add_to_list = religions_to_remove }
		}

		# Check if Hinduism should be removed
		if = {
			limit = {
				any_county_in_region = {
					region = converter_AUH_out_of_scope_region_faith_check
					count < 4 # Need to see if this should be changed, but want a decent chance of it happening
					faith.religion = religion:hinduism_religion
				}
			}
			religion:hinduism_religion = { add_to_list = religions_to_remove }
		}

		# Check if Jainism should be removed
		if = {
			limit = {
				any_county_in_region = {
					region = converter_AUH_out_of_scope_region_faith_check
					count < 4 # Need to see if this should be changed, but want a decent chance of it happening
					faith.religion = religion:jainism_religion
				}
			}
			religion:jainism_religion = { add_to_list = religions_to_remove }
		}
		
		# Remove relevant religions
		every_county_in_region = { # Regions to become Hantuist
			region = converter_AUH_out_of_scope_region_hantuist
			save_scope_as = county_check
			every_in_list = {
				list = religions_to_remove
				save_scope_as = remove_religion

				scope:county_check = {
					if = {
						limit = { faith.religion = scope:remove_religion }
						set_county_faith = faith:hantuism
					}

					holder ?= {
						if = {
							limit = { has_variable = irtock3_uncolonized_filler } # Just to double check that the rulers being affected aren't rulers converted from Imperator

							if = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:hantuism
							}

							every_courtier = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:hantuism
							}

							every_vassal_or_below = {
								if = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:hantuism
								}
								every_courtier = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:hantuism
								}
							}
						}
					}
				}

				clear_saved_scope = remove_religion
			}
			clear_saved_scope = county_check
		}

		every_county_in_region = { # Regions to become Tolotang
			region = converter_AUH_out_of_scope_region_tolotang
			save_scope_as = county_check
			every_in_list = {
				list = religions_to_remove
				save_scope_as = remove_religion

				scope:county_check = {
					if = {
						limit = { faith.religion = scope:remove_religion }
						set_county_faith = faith:tolotang
					}

					holder ?= {
						if = {
							limit = { has_variable = irtock3_uncolonized_filler } # Just to double check that the rulers being affected aren't rulers converted from Imperator

							if = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:tolotang
							}

							every_courtier = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:tolotang
							}

							every_vassal_or_below = {
								if = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:tolotang
								}
								every_courtier = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:tolotang
								}
							}
						}
					}
				}

				clear_saved_scope = remove_religion
			}
			clear_saved_scope = county_check
		}

		every_county_in_region = { # Regions to become Aluk
			region = converter_AUH_out_of_scope_region_aluk
			save_scope_as = county_check
			every_in_list = {
				list = religions_to_remove
				save_scope_as = remove_religion

				scope:county_check = {
					if = {
						limit = { faith.religion = scope:remove_religion }
						set_county_faith = faith:aluk
					}

					holder ?= {
						if = {
							limit = { has_variable = irtock3_uncolonized_filler } # Just to double check that the rulers being affected aren't rulers converted from Imperator

							if = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:aluk
							}

							every_courtier = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:aluk
							}

							every_vassal_or_below = {
								if = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:aluk
								}
								every_courtier = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:aluk
								}
							}
						}
					}
				}

				clear_saved_scope = remove_religion
			}
			clear_saved_scope = county_check
		}

		every_county_in_region = { # Regions to become Kaharingan
			region = converter_AUH_out_of_scope_region_kaharingan
			save_scope_as = county_check
			every_in_list = {
				list = religions_to_remove
				save_scope_as = remove_religion

				scope:county_check = {
					if = {
						limit = { faith.religion = scope:remove_religion }
						set_county_faith = faith:kaharingan
					}

					holder ?= {
						if = {
							limit = { has_variable = irtock3_uncolonized_filler } # Just to double check that the rulers being affected aren't rulers converted from Imperator

							if = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:kaharingan
							}

							every_courtier = {
								limit = { faith.religion = scope:remove_religion }
								set_character_faith = faith:kaharingan
							}

							every_vassal_or_below = {
								if = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:kaharingan
								}
								every_courtier = {
									limit = { faith.religion = scope:remove_religion }
									set_character_faith = faith:kaharingan
								}
							}
						}
					}
				}

				clear_saved_scope = remove_religion
			}
			clear_saved_scope = county_check
		}

		## Setup Out-of-Scope Indonesia Holdings
		# Make sure all of the counties only have their capital barony as tribal, all other baronies should have no holding
		every_county_in_region = {
			region = converter_AUH_out_of_scope_indonesia

			every_county_province = {
				if = { # Capital Barony
					limit = { is_county_capital = yes }

					if = {
						limit = {
							NOT = { has_holding_type = tribal_holding }
						}
						set_holding_type = tribal_holding
					}
				}
				else = { # Non-Capital Barony
					if = {
						limit = { has_holding = yes }
						remove_holding = yes
					}
				}
			}
		}
		{% endunless %}

		#################
		### Silk Road ###
		#################
		# Need to make sure the Silk Road Markets are buildable in their correct locations
		if = {
			limit = { has_tgp_dlc_trigger = yes }

			# It is possible that some of the baronies get special buildings like holy site buildings, so need to make sure those are removed so the market buildings can properly be added

			# Chang'an
			title:b_zhouzhi.title_province ?= {
				replace_building_effect = changan_market_01
				remove_building = changan_market_01
				add_special_building_slot = changan_market_01
			}

			# Lhasa
			title:b_potala.title_province ?= {
				replace_building_effect = lhasa_market_01
				remove_building = lhasa_market_01
				add_special_building_slot = lhasa_market_01
			}

			# Lahur
			title:b_lahur.title_province ?= {
				replace_building_effect = lahur_bazaar_01
				remove_building = lahur_bazaar_01
				add_special_building_slot = lahur_bazaar_01
			}

			# Dunhuang
			title:b_dunhuang.title_province ?= {
				replace_building_effect = dunhuang_market_01
				remove_building = dunhuang_market_01
				add_special_building_slot = dunhuang_market_01
			}

			# Khiva
			title:b_khiva.title_province ?= {
				replace_building_effect = khiva_bazaar_01
				remove_building = khiva_bazaar_01
				add_special_building_slot = khiva_bazaar_01
			}

			# Dvin
			title:b_dvin.title_province ?= {
				replace_building_effect = dvin_shuka_01
				remove_building = dvin_shuka_01
				add_special_building_slot = dvin_shuka_01
			}
		}

		###########################
		### Sinophilic Cultures ###
		###########################
		# In a converted save, there is no guarantee that most cultures were properly influenced enough to be considered "Sinophilic"
		every_culture_global = {
			limit = {
				this != culture:dongyi
				has_cultural_tradition = tradition_sinophilic
			}
			remove_culture_tradition = tradition_sinophilic
		}

		###########################
		### China De Jure Setup ###
		###########################
		# For now, making it so that any de jure hegemony that borders h_china has it's land given to China, since they would prioritize becoming Emperor of China anyway
		if = {
			limit = {
				NOT = { global_var:irtock3_enabled ?= flag:wtwsms }
			}

			# Get a list of every Chinese-ruled hegemony
			every_hegemony = {
				limit = {
					this != title:h_china
					is_titular = no
					holder.culture ?= { has_cultural_pillar = heritage_chinese }
				}
				add_to_list = chinese_hegemonies
			}

			if = {
				limit = {
					any_in_list = { list = chinese_hegemonies }
				}

				# Add all the de jure land of the Chinese hegemonies that are connected to h_china to be under h_china
				while = {
					limit = {
						any_in_list = {
							list = chinese_hegemonies
							any_title_to_title_neighboring_and_across_water_empire = { hegemony ?= title:h_china }
						}
					}

					every_in_list = {
						list = chinese_hegemonies
						limit = {
							any_title_to_title_neighboring_and_across_water_empire = { hegemony ?= title:h_china }
						}

						every_in_de_jure_hierarchy = {
							limit = { tier = tier_empire }
							set_de_jure_liege_title = title:h_china
						}

						remove_from_list = chinese_hegemonies
					}
				}
			}
		}

		
		# Government Setup
		irtock3_setup_governments = yes
	}
}

IRToCK3_game_start_after_lobby_onaction_effects = {
	effect = {
		every_player = { trigger_event = welcome.1 } # This event so far just notifies the players of the game rules added by the converter, and any relevant mods to use

		##########################
		## Dynastic Cycle Setup ##
		##########################
		# Check if h_china still needs to be properly named
		if = {
			limit = {
				exists = title:h_china.holder
				title:h_china = { has_custom_title_name = no }
			}
			title:h_china.holder = { trigger_event = tgp_dynastic_cycle.9000 }
		}
		# Make sure they properly have an Imperial Seal artifact
		else_if = {
			limit = {
				exists = title:h_china.holder
				title:h_china.holder = {
					NOT = {
						any_character_artifact = { artifact_type = seal_of_investiture_court }
					}
				}
			}
			title:h_china.holder = {
				create_artifact_dynastic_imperial_seal_effect = {
					OWNER = title:h_china.holder
					SMITH = title:h_china.holder
				}
			}
		}

		# Check if one of the Stable Phases needs to be chosen
		if = {
			limit = {
				exists = title:h_china.holder
				has_global_variable = choose_dynastic_cycle_stable_era
			}
			remove_global_variable = choose_dynastic_cycle_stable_era
			title:h_china.holder = { trigger_event = welcome.0071 }
		}
		# Otherwise, trigger initial event about Dynastic Cycle for any relevant players
		else = {
			every_player = {
				limit = { tgp_does_this_player_care_about_the_dynastic_cycle = yes }
				trigger_event = tgp_dynastic_cycle.0051
			}
		}
	}
}

# This on_action is about making sure a risturyo empire realm is properly set up with things like the ceremonial liege title
IRToCK3_ritsuryo_empire_setup = {
	trigger = {
		government_has_flag = government_is_japan_administrative # Need to be Ritsuryo
		top_liege = this # Independent
		highest_held_title_tier = tier_empire # Need to be an Emperor
		NOT = { exists = primary_title.var:administrative_ui_special_title } # Primary title can't already have a ceremonial liege title associated with it
	}
	effect = {
		save_scope_as = founder

		# If you somehow don't have a dynasty, create one
		if = {
			limit = {
				NOT = { exists = dynasty }
			}
			create_dynasty = {
				spread_to_descendants = yes
			}
		}

		# If one of your other empire titles already has a ceremonial liege title, make that your primary title (otherwise, a lot of the stuff related to ceremonial lieges breaks)
		if = {
			limit = {
				any_held_title = {
					title_tier = empire
					exists = var:administrative_ui_special_title
				}
			}
			# Save current primary title for event localization
			primary_title = { save_scope_as = ritsuryo_previous_empire_title }

			# Save new primary title that has a ceremonial liege title
			random_held_title = {
				limit = {
					tier = tier_empire
					exists = var:administrative_ui_special_title
				}
				save_scope_as = realm_title
			}

			# Remove 'tenno_restored'/'shogunate_established' from every other held empire title that has it to prevent any possible errors
			every_held_title = {
				limit = { this != scope:realm_title }
				remove_variable = tenno_restored
				remove_variable = shogunate_established
			}

			scope:realm_title.var:administrative_ui_special_title = {
				save_scope_as = ceremonial_liege_title
				
				# If someone is already holding that title, save them
				if = {
					limit = { exists = holder }
					holder = { save_scope_as = existing_ceremonial_liege }

					# If they are somehow not in your realm, save that as a flag for localization
					if = {
						limit = { holder.top_liege != scope:founder }
						holder.top_liege = { save_scope_as = ceremonial_liege_top_liege }
					}
				}
				# Otherwise, if the title has an 'imperial_house' variable, save that house as a scope
				else_if = {
					limit = { has_variable = imperial_house }
					var:imperial_house = { save_scope_as = existing_ceremonial_house }
				}
				# Otherwise, if the title has an 'imperial_dynasty' variable, save that dynasty as a scope
				else_if = {
					limit = { has_variable = imperial_dynasty }
					var:imperial_dynasty = { save_scope_as = existing_ceremonial_dynasty }
				}
			}

			set_primary_title_to = scope:realm_title

			# Set/remove laws/flags depending on the situation of the new primary title
			## If the title had 'tenno_restored' and you happen to have the ceremonial_liege title, give them primogeniture
			if = {
				limit = {
					scope:realm_title = { has_variable = tenno_restored }
					has_title = scope:ceremonial_liege_title
				}

				scope:realm_title = {
					remove_variable = shogun_flag
					set_variable = ceremonial_liege_flag
				}
				remove_character_flag = shogun_flag
				add_character_flag = ceremonial_liege_flag

				if = {
					limit = {
						NOT = { has_realm_law = single_heir_succession_law }
					}
					add_realm_law_skip_effects = single_heir_succession_law
				}
			}
			# Otherwise, make sure both variables are removed, and regency succession is put in place
			else = {
				japan_clear_flavour_flags_effect = yes

				# Localization flag setup
				if = {
					limit = { has_title = scope:ceremonial_liege_title }
					add_character_flag = ceremonial_liege_flag
					scope:realm_title = { set_variable = ceremonial_liege_flag }
				}
				else = { add_character_flag = ceremonial_regent_flag }

				if = {
					limit = {
						NOT = { has_realm_law = japanese_regency_succession_law }
					}
					add_realm_law_skip_effects = japanese_regency_succession_law
				}
			}
		}
		# Otherwise, none of your titles have a ceremonial liege, so it should be setup
		else = {
			japan_clear_flavour_flags_effect = yes
			# Remove 'tenno_restored'/'shogunate_established' from every other held empire title that has it to prevent any possible errors
			every_held_title = {
				remove_variable = tenno_restored
				remove_variable = shogunate_established
			}

			primary_title = { save_scope_as = realm_title }

			# CREATE CEREMONIAL TITLE (TITULAR)
			if = { # If your primary title is Japan and Chrysanthemum Throne is unheld, use that
				limit = {
					scope:realm_title = title:e_japan
					NOT = { exists = title:k_chrysanthemum_throne.holder }
				}
				title:k_chrysanthemum_throne = { save_scope_as = new_title }
			}
			else = { # Otherwise, create a new Ceremonial Liege title
				create_dynamic_title = {
					tier = kingdom
					name = MERITOCRATIC_CEREMONIAL_LIEGE_TITLE
				}
				scope:new_title = {
					set_coa = scope:founder.house
					set_capital_county = scope:founder.capital_county
					set_landless_title = yes
					set_figurehead_title = yes
				}
			}

			create_title_and_vassal_change = {
				type = created
				save_scope_as = change
				add_claim_on_loss = yes
			}
			scope:new_title = {
				save_scope_as = ceremonial_liege_title
				set_de_jure_liege_title = scope:realm_title
				set_definitive_form = yes
				# LINK TITLES
				set_variable = {
					name = ceremonial_title
					value = scope:realm_title
				}

				# Set this variable to indicate what dynasty should actually be on this throne
				set_variable = {
					name = imperial_dynasty
					value = scope:founder.dynasty
				}

				# Set this variable to indicate what the main house should actually be for this throne
				set_variable = {
					name = imperial_house
					value = scope:founder.house
				}

				# Set a variable on the character's House to indicate that house is associated with this ceremonial liege title
				scope:founder.house = {
					set_variable = {
						name = house_ceremonial_liege_title
						value = scope:new_title
					}
				}

				# Set a variable on the character's Dynasty to indicate that they are considered "divine", so can't take the decision to declare their bloodline holy (just like the Yamato Dynasty in the base game)
				scope:founder.dynasty = { set_variable = divine_ritsuryo_dynasty }

				# GRANT CEREMONIAL TITLE
				change_title_holder = {
					holder = scope:founder
					change = scope:change
				}
			}
			resolve_title_and_vassal_change = scope:change

			scope:realm_title = {
				set_variable = {
					name = administrative_ui_special_title
					value = scope:ceremonial_liege_title
				}

				# Set variable indicating the tenno/emperor is currently in direct control
				set_variable = {
					name = tenno_restored
					value = yes
				}

				set_variable = ceremonial_liege_flag # For localization
			}
			add_character_flag = ceremonial_liege_flag # For localization

			if = {
				limit = {
					NOT = { has_realm_law = single_heir_succession_law }
				}
				add_realm_law_skip_effects = single_heir_succession_law
			}
		}

		# Fire event to notify player about what is happening
		trigger_event = irtock3_ritsuryo_events.1
	}
}

# This on_action will trigger if you have multiple empire titles while one of them has a ceremonial liege associated with it, to alert you of the issues regarding that
IRToCK3_ritsuryo_multiple_empires = {
	trigger = {
		top_liege = this # Independent
		highest_held_title_tier = tier_empire # Need to be an Emperor
		# At least one empire title needs to already have a ceremonial liege title associated with it
		any_held_title = {
			title_tier = empire
			has_variable = administrative_ui_special_title
		}
		# Need to have more than one empire title
		any_held_title = {
			title_tier = empire
			count > 1
		}
		# If this on_action was triggered by 'on_title_gain', only display this if the title gained was an empire title to reduce spam
		trigger_if = {
			limit = { exists = scope:title }
			scope:title.tier = tier_empire
		}
	}
	effect = {
		# Trigger event notifying ruler of them having multiple empire titles, the issues, and some solutions
		trigger_event = irtock3_ritsuryo_events.2
	}
}

# This on_action will trigger when the Roman Empire is split between h_western_roman_empire and h_eastern_roman_empire, one of them is destroyed, and the other has lost a decent amount of their land. It will downgrade them to empire titles, like the Byzantine Empire
IRToCK3_roman_empire_decline_effect = {
	trigger = {
		# Someone needs to hold either the WRE or ERE, while no one else holds the other
		OR = {
			exists = title:h_western_roman_empire.holder
			exists = title:h_eastern_roman_empire.holder
		}
		## Someone holds the WRE
		trigger_if = {
			limit = { exists = title:h_western_roman_empire.holder }

			# Someone can't have the ERE
			NOT = { exists = title:h_eastern_roman_empire.holder }

			# The WRE doesn't control a lot of land
			title:h_western_roman_empire.holder = { realm_size <= 120 }
		}
		## Someone holds the ERE
		trigger_if = {
			limit = { exists = title:h_eastern_roman_empire.holder }

			# Someone can't have the WRE
			NOT = { exists = title:h_western_roman_empire.holder }

			# The ERE doesn't control a lot of land
			title:h_eastern_roman_empire.holder = { realm_size <= 120 }
		}
	}
	effect = {
		# Save the scopes for whichever half of the Roman Empire remains
		## WRE
		if = {
			limit = { exists = title:h_western_roman_empire.holder }
			title:h_western_roman_empire = {
				save_scope_as = roman_hegemony_title
				holder = { save_scope_as = roman_emperor }
				title:e_western_roman_empire = { save_scope_as = roman_empire_title }
			}
		}
		## ERE
		else_if = {
			limit = { exists = title:h_eastern_roman_empire.holder }
			title:h_eastern_roman_empire = {
				save_scope_as = roman_hegemony_title
				holder = { save_scope_as = roman_emperor }
				title:e_byzantium = { save_scope_as = roman_empire_title }
			}
		}

		# If any vassals have empire titles, destroy the empires and add them to a list for event localization later. If the empire title was de jure part of the ruler's hegemony title, drift its kingdoms to become part of the associated Rome empire title
		scope:roman_emperor = {
			every_vassal = {
				limit = { highest_held_title_tier = tier_empire }
				save_scope_as = empire_vassal
				every_held_title = {
					title_tier = empire
					if = {
						limit = { hegemony ?= scope:roman_hegemony_title }
						every_in_de_jure_hierarchy = {
							limit = { tier = tier_kingdom }
							set_de_jure_liege_title = scope:roman_empire_title
						}
					}
					scope:empire_vassal = { destroy_title = prev }
				}
				clear_saved_scope = empire_vassal
				add_to_list = empire_tier_vassals
			}
		}

		# De Jure Changes
		## Transfer land from held empire titles, then destroy them
		scope:roman_emperor = {
			every_held_title = {
				title_tier = empire
				limit = { hegemony = scope:roman_hegemony_title }

				every_in_de_jure_hierarchy = {
					limit = { tier = tier_kingdom }
					set_de_jure_liege_title = scope:roman_empire_title
				}
				scope:roman_emperor = { destroy_title = prev }
			}
		}

		## Transfer every kingdom that you completely control that is de jure under your hegemony title
		scope:roman_hegemony_title = {
			every_in_de_jure_hierarchy = {
				limit = { tier = tier_kingdom }

				if = {
					limit = {
						any_de_jure_county = {
							count = all
							holder.top_liege = scope:roman_emperor
						}
					}
					set_de_jure_liege_title = scope:roman_empire_title
				}
			}
		}

		# Give the ruler their corresponding Empire title
		create_title_and_vassal_change = {
			type = created
			save_scope_as = change
			add_claim_on_loss = no
		}
		scope:roman_empire_title = {
			change_title_holder = {
				holder = scope:roman_emperor
				change = scope:change
			}
			set_de_jure_liege_title = scope:roman_hegemony_title
		}
		resolve_title_and_vassal_change = scope:change

		# Destroy the hegemony title
		scope:roman_emperor = {
			destroy_title = scope:roman_hegemony_title
			set_primary_title_to = scope:roman_empire_title
		}

		# Notification Events
		scope:roman_emperor = { trigger_event = irtock3_roman_events.1 }
		every_player = {
			limit = {
				this != scope:roman_emperor
				in_diplomatic_range = scope:roman_emperor
			}
			trigger_event = irtock3_roman_events.1
		}
	}
}

# This on_action will be used to reset the name of the base game titles being used as Roman Praetorian Prefectures
IRToCK3_rome_praetorian_prefecture_name_reset = {
	trigger = {
		save_temporary_scope_as = ruler_temp
		scope:title ?= {
			has_variable = rome_praetorian_prefecture
			trigger_if = {
				limit = {
					has_variable = rome_praetorian_prefecture_house
					exists = scope:ruler_temp.house
				}
				NOT = { scope:ruler_temp.house = var:rome_praetorian_prefecture_house }
			}
		}
		top_liege = { is_roman_emperor_trigger = no } # A prefecture's name should potentially be reset if it is no longer under an active Rome title
	}
	effect = {
		trigger_event = {
			id = irtock3_roman_events.2
			days = 3 # Delayed because if a player had the title and died, their heir would get the event and make a choice before the player actually takes control of that character
		}
	}
}

# This on_action makes sure the name of Persia changes properly whenever somone new gets it
IRToCK3_change_persia_name = {
	trigger = {
		scope:title = title:e_persia
		title:e_persia = {
			NOR = {
				has_variable = rome_praetorian_prefecture
				custom_title_name = irtock3_rome_empire_division_persia # If Persia was made a praetorian prefecture, but became independent and its ruler chose to permanently keep its "Roman" name, it should still be using this loc key even if it doesn't have the above variable, so this shouldn't be changed
			}
		}
	}
	effect = {
		# If the character is lowborn, it should revert back to "Persian Empire" instead of keeping whatever name it had before
		if = {
			limit = {
				NOT = { exists = house }
			}
			title:e_persia = {
				reset_title_name = yes
				set_definitive_form = yes
			}
		}
		# If your from the same house as the previous holder, no reason to change the title's name
		else_if = {
			limit = {
				trigger_if = {
					limit = { exists = scope:previous_holder.house }
					NOT = { house = scope:previous_holder.house }
				}
			}
			house = { save_scope_as = new_persia_house }
			title:e_persia = {
				set_title_name_dynamic = new_persia_empire_name
				set_definitive_form = yes
			}
		}
	}
}

# This on_action makes sure the name of Persia is properly reset back to "Persian Empire" when its destroyed
IRToCK3_reset_persia_name = {
	trigger = {
		scope:landed_title = title:e_persia
		title:e_persia = {
			NOR = {
				has_variable = rome_praetorian_prefecture
				custom_title_name = irtock3_rome_empire_division_persia # If Persia was made a praetorian prefecture, but became independent and its ruler chose to permanently keep its "Roman" name, it should still be using this loc key even if it doesn't have the above variable, so this shouldn't be changed
			}
		}
	}
	effect = {
		title:e_persia = {
			reset_title_name = yes
			set_definitive_form = yes
		}
	}
}

# This on_action makes sure de jure vassals under a Rome hegemony title get their proper flavor names
IRToCK3_rome_vassal_naming_flavor = {
	trigger = {
		# To prevent this from impacting performance as much as possible, should only trigger if you are the vassal of a Rome hegemony title, or already have the relevant variable set
		OR = {
			# Already have variable set (so may lose it)
			has_variable = use_roman_vassal_naming_flag

			# Are a vassal under a Rome hegemony title
			any_liege_or_above = {
				OR = {
					has_title = title:h_roman_empire
					has_title = title:h_western_roman_empire
					has_title = title:h_eastern_roman_empire
				}
			}
		}
	}
	effect = {
		# If you are a vassal under a Rome hegemony title, you should gain the variable to indicate you can use the custom Rome vassal name flavor
		if = {
			limit = {
				exists = liege
				any_liege_or_above = {
					OR = {
						has_title = title:h_roman_empire
						has_title = title:h_western_roman_empire
						has_title = title:h_eastern_roman_empire
					}
				}
			}
			set_variable = use_roman_vassal_naming_flag
		}
		else = {
			remove_variable = use_roman_vassal_naming_flag
		}
	}
}
